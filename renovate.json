{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    "group:monorepos",
    "group:springBoot"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^pom\\.xml$"],
      "matchStrings": ["<java\\.version>(?<currentValue>\\d+)</java\\.version>"],
      "depNameTemplate": "eclipse-temurin",
      "datasourceTemplate": "docker",
      "packageNameTemplate": "eclipse-temurin"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^Dockerfile$"],
      "matchStrings": ["FROM eclipse-temurin:(?<currentValue>\\d+)-(?:jdk|jre)"],
      "depNameTemplate": "eclipse-temurin",
      "datasourceTemplate": "docker",
      "packageNameTemplate": "eclipse-temurin"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["eclipse-temurin"],
      "groupName": "java-runtime",
      "versioning": "docker"
    }
  ]
}
